+      expect(validTiers).toContain(app.tier);
+    }
+  });
+
+  it("every app has a features object", () => {
+    const apps = getAllApps();
+    for (const app of apps) {
+      expect(typeof app.features).toBe("object");
+      expect(app.features).not.toBeNull();
+    }
+  });
