+    console.log(`Total violations: ${total}`);
+    console.log(`Apps scanned: ${reports.length}`);
+    console.log("");
+
+    for (const r of reports.sort((a, b) => b.totalViolations - a.totalViolations)) {
+      if (r.totalViolations > 0) {
+        const types = Object.entries(r.byType)
