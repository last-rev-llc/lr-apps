+    category: "test",
+    vibeScore: 5,
+    origin: "test",
+    era: "2020",
+    aliases: [],
+    ...overrides,
+  };
+}
+
+const genZ: GenerationConfig = {
+  slug: "gen-z",
+  name: "Gen Z",
+  era: "1997–2012",
+  color: "#06b6d4",
