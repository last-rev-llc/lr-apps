+// @vitest-environment jsdom
+import { describe, it, expect, vi, beforeEach } from "vitest";
+import React from "react";
+import { renderWithProviders, screen } from "@repo/test-utils";
+
+vi.mock("@repo/ui", () => ({
+  Card: ({
+    children,
+    ...rest
