{
  "name": "lr-apps",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev & punchlist-qa serve & wait",
    "lint": "turbo run lint && pnpm lint:registry",
    "lint:registry": "npx tsx scripts/check-registry-db-consistency.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:rls": "pnpm --filter @repo/db exec vitest run src/__tests__/rls.test.ts",
    "create-app": "echo 'CLI not yet implemented — see tools/create-app/'",
    "audit:tokens": "npx tsx scripts/audit-tokens.ts"
  },
  "devDependencies": {
    "punchlist-qa": "^0.2.1",
    "turbo": "^2"
  },
  "packageManager": "pnpm@9.15.4"
}
